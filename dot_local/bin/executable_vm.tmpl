#!/bin/bash
set -e

VM_NAME="dev"
VM_USER="dev"
FW_NAME="dev-fw"
SSH_KEY_NAME="Development SSH Key"
SERVER_TYPE="cpx11"
IMAGE="ubuntu-24.04"
LOCATION="hil"

# shellcheck disable=SC1083
LIB_DIR={{ .chezmoi.sourceDir | quote }}/lib

vm_ip() {
    local ip
    if ! ip=$(hcloud server describe "$VM_NAME" -o format='{{ "{{.PublicNet.IPv4.IP}}" }}' 2>/dev/null) || [ -z "$ip" ]; then
        echo "No VM running" >&2
        return 1
    fi
    echo "$ip"
}

vm_wait() {
    local host
    host="$VM_USER@$(vm_ip)"
    local ssh_opts="-o StrictHostKeyChecking=no -o ConnectTimeout=5 -o PasswordAuthentication=no"
    SECONDS=0
    echo "Waiting for SSH..."
    # shellcheck disable=SC2086
    until ssh $ssh_opts "$host" true 2>/dev/null; do
        if (( SECONDS >= 60 )); then
            echo "SSH not available after 60s, check connectivity:" >&2
            # shellcheck disable=SC2086
            ssh $ssh_opts "$host" true
            return 1
        fi
        sleep 3
    done

    echo "Waiting for cloud-init (tailing log)..."
    # shellcheck disable=SC2086
    ssh $ssh_opts "$host" "sudo tail -f /var/log/cloud-init-output.log & cloud-init status --wait >/dev/null; kill %1 2>/dev/null"
    echo "Ready: $host"
}

render_cloud_init() {
    local ssh_pubkey
    ssh_pubkey=$(hcloud ssh-key describe "$SSH_KEY_NAME" -o format='{{ "{{.PublicKey}}" }}')
    op_sa_token="$(secret op-sa)" \
    hcloud_token="$HCLOUD_TOKEN" \
    ssh_pubkey="$ssh_pubkey" \
        envsubst '${op_sa_token} ${hcloud_token} ${ssh_pubkey}' < "$LIB_DIR/cloud-init.yaml.tpl"
}

ensure_firewall() {
    if hcloud firewall describe "$FW_NAME" >/dev/null 2>&1; then
        return
    fi
    hcloud firewall create --name "$FW_NAME"
    hcloud firewall add-rule "$FW_NAME" \
        --direction in --protocol tcp --port 22 \
        --source-ips 0.0.0.0/0 --source-ips ::/0 \
        --description SSH
    hcloud firewall add-rule "$FW_NAME" \
        --direction in --protocol udp --port 60000-61000 \
        --source-ips 0.0.0.0/0 --source-ips ::/0 \
        --description Mosh
}

vm_up() {
    if hcloud server describe "$VM_NAME" >/dev/null 2>&1; then
        echo "Server '$VM_NAME' already running at $(vm_ip)" >&2
        return
    fi
    ensure_firewall
    hcloud server create \
        --name "$VM_NAME" \
        --type "$SERVER_TYPE" \
        --location "$LOCATION" \
        --image "$IMAGE" \
        --ssh-key "$SSH_KEY_NAME" \
        --firewall "$FW_NAME" \
        --user-data-from-file <(render_cloud_init)
    vm_wait
}

vm_rebuild() {
    ssh-keygen -R "$(vm_ip)" 2>/dev/null || true
    hcloud server rebuild \
        --image "$IMAGE" \
        --user-data-from-file <(render_cloud_init) \
        "$VM_NAME"
    vm_wait
}

vm_destroy() {
    ssh-keygen -R "$(vm_ip)" 2>/dev/null || true
    hcloud server delete "$VM_NAME"
}

vm_status() {
    if ! hcloud server describe "$VM_NAME" >/dev/null 2>&1; then
        echo "Not running"
        return
    fi
    echo "Status: $(hcloud server describe "$VM_NAME" -o format='{{ "{{.Status}}" }}')"
    echo "IP:     $(vm_ip)"
}

vm_connect() {
    vm_up
    local host ssh_opts
    host="$VM_USER@$(vm_ip)"
    ssh_opts="ssh -o SendEnv=GITHUB_TOKEN"
    export GITHUB_TOKEN
    GITHUB_TOKEN=$(gh auth token)
    case "$1" in
        ssh)  $ssh_opts "$host" ;;
        mosh) mosh --ssh="$ssh_opts" "$host" ;;
    esac
}

case "${1:-}" in
    up|rebuild|destroy|status|ssh|mosh|ip) ;;
    *)
        echo "Usage: vm {up|rebuild|destroy|status|ssh|mosh|ip}"
        exit 1
        ;;
esac

export HCLOUD_TOKEN
HCLOUD_TOKEN=$(secret hcloud)

case "$1" in
    up)      vm_up ;;
    rebuild) vm_rebuild ;;
    destroy) vm_destroy ;;
    status)  vm_status ;;
    ssh|mosh) vm_connect "$1" ;;
    ip)      vm_ip ;;
esac
