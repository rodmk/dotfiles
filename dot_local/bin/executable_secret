#!/bin/bash
set -e

case "${1:-}" in
    hetzner-ssh) op read "op://Development/Hetzner SSH Key/private key?ssh-format=openssh" ;;
    hcloud)      op read "op://Development/Hetzner API/token" ;;
    op-sa)
        if [ -n "$OP_SERVICE_ACCOUNT_TOKEN" ]; then
            echo "$OP_SERVICE_ACCOUNT_TOKEN"
        elif [ -r "$HOME/.config/op/sa-token" ]; then
            cat "$HOME/.config/op/sa-token"
        else
            op read "op://Private/Development SA Token/credential"
        fi
        ;;
    *)
        echo "Usage: secret {hetzner-ssh|hcloud|op-sa}" >&2
        exit 1
        ;;
esac
