#!/bin/bash
set -e

VM_NAME="dev"
VM_USER="dev"
FW_NAME="dev-fw"
VOL_NAME="dev-data"
VOL_SIZE=10
SSH_KEY_NAME="Development SSH Key"
SERVER_TYPE="ccx13"
IMAGE="ubuntu-24.04"
LOCATION="hil"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

vm_ip() {
    local ip
    if ! ip=$(hcloud server describe "$VM_NAME" -o format='{{.PublicNet.IPv4.IP}}' 2>/dev/null) || [ -z "$ip" ]; then
        echo "No VM running" >&2
        return 1
    fi
    echo "$ip"
}

update_ssh_config() {
    mkdir -p ~/.ssh/config.d
    if ! grep -q 'Include config.d/\*' ~/.ssh/config 2>/dev/null; then
        printf 'Include config.d/*\n\n' | cat - ~/.ssh/config 2>/dev/null > ~/.ssh/config.tmp
        mv ~/.ssh/config.tmp ~/.ssh/config
    fi
    cat > ~/.ssh/config.d/"$VM_NAME" <<EOF
Host $VM_NAME
    HostName $1
    User $VM_USER
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
EOF
    chmod 600 ~/.ssh/config.d/"$VM_NAME"
}

vm_wait() {
    SECONDS=0
    echo "Waiting for SSH..."
    until ssh -o ConnectTimeout=5 -o PasswordAuthentication=no "$VM_NAME" true 2>/dev/null; do
        if (( SECONDS >= 60 )); then
            echo "SSH not available after 60s, check connectivity:" >&2
            ssh -o ConnectTimeout=5 -o PasswordAuthentication=no "$VM_NAME" true
            return 1
        fi
        sleep 3
    done

    echo "Waiting for cloud-init (tailing log)..."
    ssh "$VM_NAME" "sudo tail -f -n +1 /var/log/cloud-init-output.log & cloud-init status --wait >/dev/null; kill %1 2>/dev/null"
    echo "Ready: $VM_NAME"
}

vol_id() {
    hcloud volume describe "$VOL_NAME" -o format='{{.ID}}' 2>/dev/null
}

render_cloud_init() {
    local ssh_pubkey
    ssh_pubkey=$(hcloud ssh-key describe "$SSH_KEY_NAME" -o format='{{.PublicKey}}')
    op_sa_token="$(secret op-sa)" \
    hcloud_token="$HCLOUD_TOKEN" \
    ssh_pubkey="$ssh_pubkey" \
    vol_device="/dev/disk/by-id/scsi-0HC_Volume_$(vol_id)" \
        envsubst '${op_sa_token} ${hcloud_token} ${ssh_pubkey} ${vol_device}' < "$SCRIPT_DIR/cloud-init.yaml.tpl"
}

ensure_firewall() {
    if hcloud firewall describe "$FW_NAME" >/dev/null 2>&1; then
        return
    fi
    hcloud firewall create --name "$FW_NAME"
    hcloud firewall add-rule "$FW_NAME" \
        --direction in --protocol tcp --port 22 \
        --source-ips 0.0.0.0/0 --source-ips ::/0 \
        --description SSH
    hcloud firewall add-rule "$FW_NAME" \
        --direction in --protocol udp --port 60000-61000 \
        --source-ips 0.0.0.0/0 --source-ips ::/0 \
        --description Mosh
}

ensure_volume() {
    if hcloud volume describe "$VOL_NAME" >/dev/null 2>&1; then
        return
    fi
    hcloud volume create --name "$VOL_NAME" --size "$VOL_SIZE" --location "$LOCATION" --format ext4
}

vm_up() {
    if hcloud server describe "$VM_NAME" >/dev/null 2>&1; then
        update_ssh_config "$(vm_ip)"
        echo "Server '$VM_NAME' already running at $(vm_ip)" >&2
        return
    fi
    ensure_firewall
    ensure_volume
    hcloud server create \
        --name "$VM_NAME" \
        --type "$SERVER_TYPE" \
        --location "$LOCATION" \
        --image "$IMAGE" \
        --ssh-key "$SSH_KEY_NAME" \
        --firewall "$FW_NAME" \
        --volume "$VOL_NAME" \
        --user-data-from-file <(render_cloud_init)
    update_ssh_config "$(vm_ip)"
    vm_wait
}

vm_rebuild() {
    if [ "${1:-}" = "--vol" ]; then
        hcloud server shutdown --wait "$VM_NAME"
        hcloud volume detach "$VOL_NAME"
        hcloud volume delete "$VOL_NAME"
        ensure_volume
        hcloud volume attach --server "$VM_NAME" "$VOL_NAME"
        echo "Volume '$VOL_NAME' recreated"
    fi
    hcloud server rebuild \
        --image "$IMAGE" \
        --user-data-from-file <(render_cloud_init) \
        "$VM_NAME"
    update_ssh_config "$(vm_ip)"
    vm_wait
}

vm_destroy() {
    rm -f ~/.ssh/config.d/"$VM_NAME"
    hcloud server delete "$VM_NAME" 2>/dev/null || true
    if [ "${1:-}" = "--vol" ]; then
        hcloud volume delete "$VOL_NAME"
        echo "Volume '$VOL_NAME' deleted"
    fi
}

vm_status() {
    if ! hcloud server describe "$VM_NAME" >/dev/null 2>&1; then
        echo "Not running"
        return
    fi
    echo "Status: $(hcloud server describe "$VM_NAME" -o format='{{.Status}}')"
    echo "IP:     $(vm_ip)"
}

vm_connect() {
    vm_up
    case "$1" in
        ssh)  ssh "$VM_NAME" ;;
        mosh) mosh "$VM_NAME" ;;
        code) code --folder-uri "vscode-remote://ssh-remote+$VM_NAME/home/$VM_USER" ;;
    esac
}

case "${1:-}" in
    up|rebuild|destroy|status|ssh|mosh|code|ip) ;;
    *)
        echo "Usage: vm {up|rebuild [--vol]|destroy [--vol]|status|ssh|mosh|code|ip}"
        exit 1
        ;;
esac

export HCLOUD_TOKEN
HCLOUD_TOKEN=$(secret hcloud)

case "$1" in
    up)      vm_up ;;
    rebuild) vm_rebuild "${@:2}" ;;
    destroy) vm_destroy "${@:2}" ;;
    status)  vm_status ;;
    ssh|mosh|code) vm_connect "$1" ;;
    ip)      vm_ip ;;
esac
