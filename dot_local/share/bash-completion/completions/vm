_vm() {
    local cur prev
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    case "$prev" in
        image) COMPREPLY=($(compgen -W 'build status delete' -- "$cur")) ;;
        vm)    COMPREPLY=($(compgen -W 'up rebuild destroy status ssh mosh ip image' -- "$cur")) ;;
    esac
}
complete -F _vm vm
