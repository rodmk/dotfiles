{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["lib/pkg/.+\\.sh$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[\\S]+) depName=(?<depName>[\\S]+)(?: versioning=(?<versioning>[\\S]+))?\\n[A-Z_]+=(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    { "matchPackageNames": ["node"], "allowedVersions": "22.x" }
  ]
}
