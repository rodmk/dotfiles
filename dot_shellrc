# shellcheck shell=bash
is_bash=
is_zsh=
if [ -n "$ZSH_VERSION" ]; then
    is_zsh=1
elif [ -n "$BASH_VERSION" ]; then
    is_bash=1
fi

# ============================================================================
# PATH
# ============================================================================

export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# ============================================================================
# 1PASSWORD
# ============================================================================

if [ -r "$HOME/.config/op/sa-token" ]; then
    OP_SERVICE_ACCOUNT_TOKEN=$(cat "$HOME/.config/op/sa-token")
    export OP_SERVICE_ACCOUNT_TOKEN
fi

# ============================================================================
# EDITOR
# ============================================================================

export EDITOR='nano'

# ============================================================================
# PAGER
# ============================================================================

# R: ANSI color support
# F: quit if output fits on one screen
# i: case-insensitive search (unless uppercase used)
# M: verbose prompt with line numbers and percentage
export LESS='-RFiM'

# ============================================================================
# COLORS
# ============================================================================

case "$(uname -s)" in
Darwin)
    export CLICOLOR=1
    export LSCOLORS=Gxfxcxdxbxegedabagacad
    ;;
*)
    alias ls='ls --color=auto'
    ;;
esac

# ============================================================================
# HISTORY
# ============================================================================

export HISTSIZE=10000
export SAVEHIST=10000

[ "$is_zsh" ] && {
    setopt APPEND_HISTORY
    setopt HIST_IGNORE_DUPS
    setopt HIST_FIND_NO_DUPS
    setopt HIST_IGNORE_ALL_DUPS
    setopt HIST_SAVE_NO_DUPS
    setopt SHARE_HISTORY
}

[ "$is_bash" ] && {
    export HISTCONTROL=ignoredups:erasedups
    shopt -s histappend
}

# ============================================================================
# COMPLETION
# ============================================================================

[ "$is_zsh" ] && {
    # shellcheck disable=SC2206
    fpath=(~/.local/share/zsh/site-functions $fpath)
    autoload -Uz compinit && compinit
}

[ "$is_bash" ] && {
    # shellcheck source=/dev/null
    [ -f /etc/bash_completion ] && . /etc/bash_completion
    # shellcheck source=/dev/null
    [ -f /usr/local/etc/bash_completion ] && . /usr/local/etc/bash_completion
}

# ============================================================================
# PROMPT
# ============================================================================

# shellcheck source=/dev/null
. "$HOME/.local/lib/prompt-helpers.sh"

[ "$is_zsh" ] && {
    _zsh_precmd() {
        local base dir="${PWD/#$HOME/~}"
        base=$(build_base_prompt "$dir" . zsh)
        # shellcheck disable=SC2034
        PROMPT="${base} %# "
    }
    precmd_functions+=(_zsh_precmd)
}

[ "$is_bash" ] && {
    _prompt_command() {
        local base dir="${PWD/#$HOME/~}"
        base=$(build_base_prompt "$dir" . bash)
        PS1="${base} \$ "
    }
    PROMPT_COMMAND=_prompt_command
}

# ============================================================================
# DIRENV
# ============================================================================

if command -v direnv >/dev/null 2>&1; then
    [ "$is_zsh" ] && {
        eval "$(direnv hook zsh)"
    }
    [ "$is_bash" ] && {
        eval "$(direnv hook bash)"
    }
fi

# ============================================================================
# HETZNER
# ============================================================================

# Lazy-load API token from 1Password on first use
hcloud() {
    if [ -z "$HCLOUD_TOKEN" ]; then
        HCLOUD_TOKEN=$(secret hcloud)
        export HCLOUD_TOKEN
    fi
    command hcloud "$@"
}

# ============================================================================
# GEMINI
# ============================================================================

# Lazy-install on first use
gemini() {
    if ! command -v gemini >/dev/null 2>&1; then
        echo "Installing gemini-cli..."
        sudo npm install -g @google/gemini-cli
    fi
    command gemini "$@"
}

# ============================================================================
# ALIASES
# ============================================================================

alias g='git'
alias tm='tmux new-session -A -s main'
alias yoloclaude='claude --dangerously-skip-permissions --model opus'

[ "$is_zsh" ] && compdef g=git
